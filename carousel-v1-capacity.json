        { "type": "decoration", "name": "cornerBracket" },
        { "type": "brand", "text": "Encoded.Ai", "position": "top" },
        { "type": "spacer" },
        { "type": "eyebrow", "text": "Nervous System Capacity", "marginBottom": "36px" },
        { "type": "headline", "style": "hxl", "text": "Your nervous\nsystem has\na ceiling." },
        { "type": "gap", "size": "g20" },
        { "type": "subhead", "text": "And almost every performance problem is happening above it." },
        { "type": "gap", "size": "g24" },
        { "type": "rule" }
      ]
    },
    {
      "id": 2,
      "type": "statement",
      "counter": "02 / 08",
      "elements": [
        { "type": "slideCounter", "text": "02 / 08" },
        { "type": "spacer" },
        { "type": "eyebrow", "text": "The Definition", "marginBottom": "36px" },
        { "type": "headline", "style": "hl", "text": "It's a ceiling.\nNot a feeling." },
        { "type": "gap", "size": "g16" },
        { "type": "body", "muted": true, "text": "The maximum demand your nervous system can hold before clear thinking fragments." },
        { "type": "spacer" }
      ]
    },
    {
      "id": 3,
      "type": "numberedList",
      "counter": "03 / 08",
      "elements": [
        { "type": "slideCounter", "text": "03 / 08" },
        { "type": "decoration", "name": "bgWord", "text": "3×" },
        { "type": "eyebrow", "text": "The Architecture", "marginBottom": "36px" },
        { "type": "headline", "style": "hm", "text": "Three systems.\nOne ceiling.", "marginBottom": "44px" },
        {
          "type": "numberedList",
          "items": [
            { "number": "01", "text": "Vagal Tone — how fast you recover" },
            { "number": "02", "text": "HPA-Axis — resting cortisol baseline" },
            { "number": "03", "text": "Amygdala — threat threshold" }
          ]
        }
      ]
    },
    {
      "id": 4,
      "type": "statement",
      "counter": "04 / 08",
      "elements": [
        { "type": "slideCounter", "text": "04 / 08" },
        { "type": "spacer" },
        { "type": "eyebrow", "text": "Same Effort", "marginBottom": "36px" },
        { "type": "headline", "style": "hl", "text": "Two people.\nSame work.\nDifferent ceiling." },
        { "type": "gap", "size": "g16" },
        { "type": "body", "muted": true, "text": "One drains in an hour. One sustains all day. The difference isn't effort." },
        { "type": "spacer" }
      ]
    },
    {
      "id": 5,
      "type": "numberedList",
      "counter": "05 / 08",
      "elements": [
        { "type": "slideCounter", "text": "05 / 08" },
        { "type": "decoration", "name": "bgWord", "text": "signs" },
        { "type": "eyebrow", "text": "Recognisable Signs", "marginBottom": "36px" },
        { "type": "headline", "style": "hm", "text": "Not personality.\nOutputs.", "marginBottom": "44px" },
        {
          "type": "numberedList",
          "items": [
            { "number": "01", "text": "Thinking fragments under load" },
            { "number": "02", "text": "Emotions arrive before conscious choice" },
            { "number": "03", "text": "Output quality collapses as the day progresses" }
          ]
        }
      ]
    },
    {
      "id": 6,
      "type": "quote",
      "counter": "06 / 08",
      "elements": [
        { "type": "slideCounter", "text": "06 / 08" },
        { "type": "spacer" },
        { "type": "quoteMark" },
        { "type": "gap", "size": "g16" },
        { "type": "quoteText", "text": "It's not how hard\nyou work. It's the size\nof the container." },
        { "type": "spacer" }
      ]
    },
    {
      "id": 7,
      "type": "statement",
      "counter": "07 / 08",
      "elements": [
        { "type": "slideCounter", "text": "07 / 08" },
        { "type": "spacer" },
        { "type": "eyebrow", "text": "The Critical Distinction", "marginBottom": "36px" },
        { "type": "headline", "style": "hl", "text": "Regulation restores.\nCapacity raises\nthe ceiling." },
        { "type": "gap", "size": "g16" },
        { "type": "body", "muted": true, "text": "If regulation is the only tool, the ceiling never moves." },
        { "type": "spacer" }
      ]
    },
    {
      "id": 8,
      "type": "closing",
      "elements": [
        { "type": "decoration", "name": "cornerBracket" },
        { "type": "spacer" },
        { "type": "headline", "style": "hl", "text": "Change the container.\nEverything inside\nfollows." },
        { "type": "spacer" },
        { "type": "rule" },
        { "type": "gap", "size": "g20" },
        { "type": "brand", "text": "Encoded.Ai", "position": "bottom" }
      ]
